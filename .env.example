# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=example.com,www.example.com,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Database
# If you use docker-compose from this repo, keep DB_HOST=db
DB_ENGINE=django.db.backends.postgresql
DB_NAME=perfecthome
DB_USER=perfecthome_user
DB_PASSWORD=change-me-to-a-strong-password
DB_HOST=db
DB_PORT=5432

# Contact
CONTACT_ADDRESS=Tashkent, Uzbekistan
CONTACT_PHONE=+998 (00) 000-00-00
CONTACT_EMAIL=info@example.com
CONTACT_MAP_EMBED_URL=https://www.google.com/maps
