# Django
# Productionda yangi random qiymat bering:
# python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-this-secret-key
# Serverda False bo'lishi kerak. Local development uchun True qiling.
DJANGO_DEBUG=False
# Local default hostlar. Productionda domen va kerak bo'lsa server IP ni qo'shing.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Local HTTP uchun bo'sh qoldirsa bo'ladi. Productionda to'liq https origin yozing.
DJANGO_CSRF_TRUSTED_ORIGINS=
# Production example:
# DJANGO_ALLOWED_HOSTS=example.com,www.example.com,123.123.123.123
# DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=perfecthome
DB_USER=perfecthome_user
DB_PASSWORD=change-this-db-password
# Shu repodagi docker-compose ishlatilsa DB_HOST=db bo'ladi.
# Django hostda to'g'ridan-to'g'ri ishga tushsa 127.0.0.1 yoki DB server hostname yozing.
DB_HOST=db
DB_PORT=5432

# Contact
CONTACT_ADDRESS=Tashkent, Uzbekistan
CONTACT_PHONE=+998 (00) 000-00-00
CONTACT_EMAIL=info@perfecthome.uz
CONTACT_MAP_EMBED_URL=https://www.google.com/maps
